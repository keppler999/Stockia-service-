{
  "expo": {
    "name": "Stockia",
    "slug": "stockia",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cd.spiraleagence.stockia"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "package": "cd.spiraleagence.stockia",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Stockia utilise la caméra pour scanner les codes-barres."
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      "expo-splash-screen"
    ]
  }
}
